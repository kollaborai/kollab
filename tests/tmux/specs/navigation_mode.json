{
  "name": "navigation-mode",
  "description": "Verify Tab enters nav mode, arrows work, Esc exits",
  "config": {
    "command": "python main.py",
    "show_captures": true,
    "app_init_sleep": 3,
    "term_width": 120,
    "term_height": 35,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },

    { "action": "section", "title": "Test 1: Tab enters navigation mode" },
    { "action": "nav_mode" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "NAVIGATE", "description": "Navigation mode shows NAVIGATE indicator" },

    { "action": "section", "title": "Test 2: Arrow keys work in nav mode" },
    { "action": "arrow", "direction": "Right" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "NAVIGATE", "description": "Still in navigation mode after arrow" },

    { "action": "section", "title": "Test 3: Esc returns to input mode" },
    { "action": "escape" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_not_contains", "pattern": "NAVIGATE", "description": "NAVIGATE indicator hidden after Esc" },

    { "action": "section", "title": "Test 4: Can enter edit mode" },
    { "action": "nav_mode" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "edit_mode" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "EDIT", "description": "Edit mode shows EDIT indicator" },

    { "action": "section", "title": "Test 5: Esc exits edit mode back to nav mode" },
    { "action": "escape" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "NAVIGATE", "description": "Back to navigation mode" }
  ]
}
