{
  "name": "mcp-comprehensive",
  "description": "Comprehensive MCP test: all commands, menu visibility, activation",
  "config": {
    "command": "python main.py",
    "show_captures": true,
    "app_init_sleep": 4,
    "term_width": 120,
    "term_height": 40,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },
    { "action": "capture" },
    { "action": "info", "message": "App started, checking initial state" },

    { "action": "section", "title": "Test 1: /mcp command menu visibility" },
    { "action": "type", "text": "/mcp" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "mcp|MCP|servers", "description": "/mcp appears in command menu" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },

    { "action": "section", "title": "Test 2: /mcp subcommand menu" },
    { "action": "type", "text": "/mcp " },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "setup|list|show|tools|servers|enable|disable|test", "description": "Subcommands visible" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },

    { "action": "section", "title": "Test 3: /mcp setup - wizard available" },
    { "action": "slash_command", "command": "mcp", "subcommand": "setup" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "Setup|Wizard|Server|config|MCP", "description": "/mcp setup activates" },
    { "action": "escape" },
    { "action": "sleep", "seconds": 0.5 },

    { "action": "section", "title": "Test 4: /mcp show - status panel" },
    { "action": "slash_command", "command": "mcp", "subcommand": "show" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "MCP|Status|Server|offline|not available", "description": "/mcp show displays status" },

    { "action": "section", "title": "Test 5: /mcp list - server listing" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "slash_command", "command": "mcp", "subcommand": "list" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "MCP|Server|Tool|not available|configured", "description": "/mcp list executes" },

    { "action": "section", "title": "Test 6: /mcp servers - server status" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "slash_command", "command": "mcp", "subcommand": "servers" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "MCP|Server|not available|configured|Total", "description": "/mcp servers executes" },

    { "action": "section", "title": "Test 7: /mcp tools - tool listing" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "slash_command", "command": "mcp", "subcommand": "tools" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "MCP|Tool|not available|No.*tool", "description": "/mcp tools executes" },

    { "action": "section", "title": "Test 8: /mcp subcommand filtering - 's' filter" },
    { "action": "type", "text": "/mcp s" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "setup|show|servers", "description": "Subcommands filtered to 's'" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },

    { "action": "section", "title": "Test 9: /mcp subcommand filtering - 'l' filter" },
    { "action": "type", "text": "/mcp l" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "list", "description": "Subcommands filtered to 'l'" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },

    { "action": "section", "title": "Test 10: /mcp subcommand filtering - 't' filter" },
    { "action": "type", "text": "/mcp t" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "test|tools", "description": "Subcommands filtered to 't'" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },

    { "action": "section", "title": "Test 11: Escape clears command input" },
    { "action": "type", "text": "/mcp" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "escape" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "info", "message": "Escape pressed - menu should close" },

    { "action": "section", "title": "Test 12: Clear input with Ctrl+U" },
    { "action": "type", "text": "some text here" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "some text|Pasted", "description": "Text entered" },
    { "action": "clear_input" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "capture" },
    { "action": "assert_not_contains", "pattern": "some text here", "description": "Text cleared" }
  ]
}
