{
  "name": "permission-real-interactive",
  "description": "Verify permission UI actually displays for user interaction",
  "config": {
    "command": "python main.py",
    "show_captures": false,
    "app_init_sleep": 3,
    "term_width": 120,
    "term_height": 30,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },

    { "action": "section", "title": "Step 1: Trigger tool requiring permission" },
    { "action": "send_keys", "keys": "Read the README.md file" },
    { "action": "send_keys", "keys": "Enter" },
    { "action": "sleep", "seconds": 3 },
    { "action": "capture" },

    { "action": "section", "title": "Step 2: Verify no UI callback error" },
    { "action": "assert_not_contains", "pattern": "Confirmation required but no UI available", "description": "Should not see UI callback error" },

    { "action": "section", "title": "Step 3: Approve permission" },
    { "action": "send_keys", "keys": "y" },
    { "action": "sleep", "seconds": 2 },
    { "action": "capture" }
  ]
}
