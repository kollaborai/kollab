{
  "name": "verify_directory_change",
  "description": "Verify directory change via modal works correctly",
  "config": {
    "command": "python main.py",
    "show_captures": false,
    "app_init_sleep": 3,
    "term_width": 120,
    "term_height": 35,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },

    { "action": "section", "title": "Step 1: Open directory modal" },
    { "action": "slash_command", "command": "directory" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "Directory Navigator|Current:", "description": "Directory modal opened" },

    { "action": "section", "title": "Step 2: Navigate to parent directory and select" },
    { "action": "send_keys", "keys": "Down" },
    { "action": "sleep", "seconds": 0.3 },
    { "action": "send_keys", "keys": "Enter" },
    { "action": "sleep", "seconds": 1 },

    { "action": "section", "title": "Step 3: Verify directory changed" },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "Changed to|ok", "description": "Directory changed successfully" }
  ]
}
