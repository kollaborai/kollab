{
  "name": "tmux-simple",
  "description": "Simple tmux test to verify app starts in tmux session",
  "config": {
    "command": "python main.py",
    "show_captures": false,
    "app_init_sleep": 5,
    "term_width": 120,
    "term_height": 35,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },
    { "action": "capture" },

    { "action": "section", "title": "Test 1: Application started" },
    { "action": "assert_contains", "pattern": "Kollab|Ready!", "description": "Application started in tmux session" }
  ]
}
