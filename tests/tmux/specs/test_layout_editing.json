{
  "name": "layout-editing",
  "description": "Verify navigation mode and layout editing features",
  "config": {
    "command": "python main.py",
    "show_captures": false,
    "app_init_sleep": 5,
    "term_width": 120,
    "term_height": 30,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },
    { "action": "capture" },

    { "action": "section", "title": "Test 1: Application started" },
    { "action": "assert_contains", "pattern": "Kollab|Ready!", "description": "Application started" },

    { "action": "section", "title": "Test 2: Enter navigation mode" },
    { "action": "nav_mode" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },

    { "action": "section", "title": "Test 3: Navigation mode active" },
    { "action": "assert_contains", "pattern": "NAV|navigation|Navigation|EDIT|Edit", "description": "Navigation mode indicator visible" },

    { "action": "section", "title": "Test 4: Add row with Shift+A" },
    { "action": "send_keys", "keys": "A" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },

    { "action": "section", "title": "Test 5: Delete widget with d" },
    { "action": "send_keys", "keys": "d" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },

    { "action": "section", "title": "Test 6: Exit navigation mode" },
    { "action": "escape" },
    { "action": "sleep", "seconds": 0.5 },
    { "action": "capture" },

    { "action": "section", "title": "Test 7: Returned to normal mode" },
    { "action": "assert_contains", "pattern": "Ready!|User:|You:|❯|Type your message", "description": "Returned to normal mode" }
  ]
}
