{
  "name": "force breakthrough via /hub wake",
  "description": "Waiting agent woken by /hub wake (force semantics)",
  "config": {
    "command": "kollab",
    "app_init_sleep": 4,
    "show_captures": false
  },
  "steps": [
    { "action": "start_app" },
    { "action": "section", "title": "Enter waiting state" },
    { "action": "type", "text": "emit <wait_for_user/> now" },
    { "action": "send_keys", "keys": "Enter" },
    { "action": "sleep", "seconds": 3 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "parked" },
    { "action": "section", "title": "Check status shows waiting" },
    { "action": "slash_command", "command": "hub", "subcommand": "status" },
    { "action": "sleep", "seconds": 1 },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "waiting" },
    { "action": "section", "title": "Wake via /hub wake (uses force=true internally)" },
    { "action": "slash_command", "command": "hub", "subcommand": "wake default" },
    { "action": "sleep", "seconds": 2 },
    { "action": "capture" },
    { "action": "assert_not_contains", "pattern": "not in waiting" }
  ]
}
