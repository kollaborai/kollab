{
  "name": "permission-ui-interactive",
  "description": "Verify permission UI displays, accepts keypresses, and allows tool execution",
  "config": {
    "command": "python main.py",
    "show_captures": false,
    "app_init_sleep": 2.5,
    "term_width": 120,
    "term_height": 30,
    "key_delay": 0.3,
    "menu_delay": 0.5
  },
  "steps": [
    { "action": "start_app" },

    { "action": "section", "title": "Step 1: Verify application started" },
    { "action": "capture" },
    { "action": "assert_contains", "pattern": "v[0-9]+\\.[0-9]+\\.[0-9]+|█|▄", "description": "Application started successfully" },

    { "action": "section", "title": "Step 2: Trigger tool requiring permission (file_read)" },
    { "action": "send_keys", "keys": "What is in the README.md file?" },
    { "action": "send_keys", "keys": "Enter" },
    { "action": "sleep", "seconds": 3 },
    { "action": "capture" },

    { "action": "section", "title": "Step 3: Verify permission prompt (no UI error)" },
    { "action": "assert_not_contains", "pattern": "Confirmation required but no UI available", "description": "Should not see UI callback error" },

    { "action": "section", "title": "Step 4: Send approval keypress (y)" },
    { "action": "send_keys", "keys": "y" },
    { "action": "sleep", "seconds": 2 },
    { "action": "capture" },

    { "action": "section", "title": "Step 5: Verify tool execution after approval" },
    { "action": "assert_not_contains", "pattern": "error.*ui available", "description": "Should not see permission UI error after approval" }
  ]
}
