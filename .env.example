# Kollab Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# LLM Profile Configuration (via environment variables)
# ============================================================================
# Kollab supports configuring LLM profiles through env vars.
# Each profile uses a prefix: KOLLAB_{PROFILENAME}_
# The "DEFAULT" profile is used when no --profile flag is specified.

# Default profile
KOLLAB_DEFAULT_BASE_URL=https://api.openai.com/v1/chat/completions
KOLLAB_DEFAULT_API_KEY=<your-api-key>
KOLLAB_DEFAULT_MODEL=gpt-4
KOLLAB_DEFAULT_MAX_TOKENS=4096
KOLLAB_DEFAULT_TEMPERATURE=0.7
KOLLAB_DEFAULT_TIMEOUT=60000

# Example: Additional profile (use with --profile myprofile)
# KOLLAB_MYPROFILE_BASE_URL=https://api.anthropic.com/v1/messages
# KOLLAB_MYPROFILE_API_KEY=<your-api-key>
# KOLLAB_MYPROFILE_MODEL=claude-sonnet-4-6
# KOLLAB_MYPROFILE_PROVIDER=anthropic
# KOLLAB_MYPROFILE_MAX_TOKENS=8192

# ============================================================================
# System Prompt (optional)
# ============================================================================
# KOLLAB_SYSTEM_PROMPT="You are a helpful coding assistant."
# KOLLAB_SYSTEM_PROMPT_FILE="./custom_prompt.md"

# ============================================================================
# Advanced Settings
# ============================================================================
# KOLLAB_COLOR_MODE=truecolor    # truecolor, 256, none
# KOLLAB_NO_AUTO_DETECT=1        # Disable auto-detection of LLM providers
# KOLLAB_MODEL=gpt-4             # Override model for all profiles
